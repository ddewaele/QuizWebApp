generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts AuthAccount[]
  quizzes  Quiz[]
  attempts QuizAttempt[]
}

model AuthAccount {
  id                String @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Quiz {
  id            String  @id @default(cuid())
  title         String
  description   String?
  subject       String?
  metaVersion   String?
  metaCreated   String?
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceJson    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]
  shares    QuizShare[]

  @@index([userId])
}

model QuizQuestion {
  id            String  @id @default(cuid())
  quizId        String
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId    Int
  questionText  String
  options       Json
  correctAnswer Json
  sortOrder     Int
  difficulty    String?
  topic         String?
  tags          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers QuizAttemptAnswer[]

  @@unique([quizId, questionId])
  @@index([quizId])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int
  percentage     Float
  completedAt    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers QuizAttemptAnswer[]

  @@index([userId])
  @@index([quizId])
}

model QuizAttemptAnswer {
  id           String       @id @default(cuid())
  attemptId    String
  attempt      QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId   String
  question     QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedKeys Json
  isCorrect    Boolean

  createdAt DateTime @default(now())

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model QuizShare {
  id          String          @id @default(cuid())
  quizId      String
  quiz        Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  email       String
  accessLevel QuizAccessLevel @default(TAKER)
  status      ShareStatus     @default(PENDING)
  token       String          @unique @default(cuid())
  sharedBy    String
  sharedAt    DateTime        @default(now())
  acceptedAt  DateTime?

  @@unique([quizId, email])
  @@index([quizId])
  @@index([email])
  @@index([token])
}

enum QuizAccessLevel {
  TAKER
  VIEWER
}

enum ShareStatus {
  PENDING
  ACCEPTED
  REVOKED
}
