    "@fastify/secure-session": "^8.1.0",
    "@prisma/client": "^6.2.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
