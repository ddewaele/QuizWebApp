# Database (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://quiz:quiz_dev_password@localhost:5433/quizapp?schema=public"

# Google OAuth — create credentials at https://console.cloud.google.com
# Authorised redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Session encryption key — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-64-char-hex-string-here"

# Anthropic — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Server
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"

# Client origin (must match Vite dev server port and Google OAuth redirect URI)
CLIENT_URL="http://localhost:5174"
