# Database
DATABASE_URL="postgresql://quiz:quiz_dev_password@localhost:5433/quizapp?schema=public"

# Google OAuth (see README for setup instructions)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Session (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET="generate-a-64-char-hex-string-here"

# Server
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"

# Client origin (must match Vite dev server port and Google OAuth redirect URI)
CLIENT_URL="http://localhost:5174"
